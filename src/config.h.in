#pragma once

#include <raylib.h>

namespace game
{
    class Config final
    {
    public:
        inline static constexpr const char* kProjectName = "@PROJECT_NAME@";
        inline static constexpr const char* kProjectVersion = "@PROJECT_VERSION@";
        inline static constexpr const char* kProjectVersionMajor = "@PROJECT_VERSION_MAJOR@";
        inline static constexpr const char* kProjectVersionMinor = "@PROJECT_VERSION_MINOR@";
        inline static constexpr const char* kProjectVersionPatch = "@PROJECT_VERSION_PATCH@";

        // Width and Height of the game stage. The stage will be scaled with the window size
        inline static constexpr int kVirtualStageWidth = 512;
        inline static constexpr int kVirtualStageHeight = 320;

        inline static constexpr int kWindowedModeWidth = 1280;
        inline static constexpr int kWindowedModeHeight = 720;

        // Target FPS, default is 60 fps
        inline static constexpr int kTargetFps = 60;

        // Start game in window or fullscreen mode
        inline static constexpr const bool kFullScreen = true;

        // Define if the game uses a mouse/mouse pointer
        // The mouse position is then accessible in game::core::Store in the mouse_position attribute
        // Please do not use the Raylib function GetMousePosition()
        inline static constexpr const bool kUseMouse = false;

        // Raylib window config flags, e.g. for resizable window and vertical synchronisation
        // Default: GAME_CONFIG_FLAGS FLAG_WINDOW_RESIZABLE | FLAG_VSYNC_HINT | FLAG_MSAA_4X_HINT
        inline static constexpr const int kWindowFlags = FLAG_WINDOW_RESIZABLE | FLAG_VSYNC_HINT | FLAG_MSAA_4X_HINT;

        // Texture scale filter to use, e.g. TEXTURE_FILTER_POINT, TEXTURE_FILTER_BILINEAR etc.
        // Default: TEXTURE_FILTER_POINT for no filter, only pixel approximation
        inline static constexpr const int kTextureFilter = TEXTURE_FILTER_POINT;

        // Define Raylib exit key - KEY_NULL means that no key leads to the termination of the program
        // Raylib default is KEY_ESCAPE
        inline static constexpr const int kExitKey = KEY_NULL;

        // Defines if Raylib audio should be enabled
        inline static constexpr const bool kAudio = true;

        // Class by Andreas

                //Warrior Stats - Default 0 | Sprite Path - Default assets/graphics/XXXX.png
                inline static constexpr int warrior_hp = 0;
                inline static constexpr float warrior_speed = 0.0f;
                inline static constexpr int warrior_damage = 0;
                inline static constexpr const char* warrior_sprite_path = "assets/graphics/XXXX.png";

                // drains HP every second - Default 0 HP
                inline static constexpr float hp_drain = 0.0f;

        // Control Settings
        inline static constexpr const int key_Up = KEY_W;
        inline static constexpr const int key_Down = KEY_S;
        inline static constexpr const int key_Left = KEY_A;
        inline static constexpr const int key_Right = KEY_D;

        inline static constexpr const int tile_Size = 16;

        // Player specific config
        inline static constexpr float player_Start_X = 100.0f;
        inline static constexpr float player_Start_Y = 100.0f;
        inline static constexpr float player_Movement_Speed = 32.0f;
        inline static constexpr float player_Width = 16.0f;
        inline static constexpr float player_Height = 24.0f;

        // Player Attack Config
        inline static constexpr float player_Attack_Duration = 0.3f; // How long the attack hitbox is active (in seconds)
        inline static constexpr float player_Hitbox_Size = 20.0f;   // Diameter/width of the melee attack hitbox
        inline static constexpr float player_Attack_Cooldown = 0.3f;

        inline static constexpr const int key_Melee_Attack = KEY_K;

        // --- Gemeinsame Eigenschaften für alle Movable Walls in Puzzle 1 ---
        // Visuelle Größe einer Movable Wall (basierend auf 2x2 Kacheln)
        inline static constexpr float movable_Wall_Visual_Width = game::Config::tile_Size * 2.0f;
        inline static constexpr float movable_Wall_Visual_Height = game::Config::tile_Size * 2.0f;

        // Hitbox-Dimensionen (kleiner als die visuelle Größe, um Überlappung zu ermöglichen)
        inline static constexpr float movable_Wall_Hitbox_Width = game::Config::tile_Size * 2.0f; // Beispiel: volle Breite
        inline static constexpr float movable_Wall_Hitbox_Height = game::Config::tile_Size * 1.0f; // Beispiel: nur die untere Kachelreihe als Hitbox

        // Hitbox-Offset relativ zur oberen linken Ecke des visuellen 2x2 Sprites

        // Y-Offset von tile_Size bedeutet wo die Hitbox der Wand beginnt. Standard gerade = oberes Tile bleibt frei
        inline static constexpr float movable_Wall_Hitbox_Offset_X = 0.0f;
        inline static constexpr float movable_Wall_Hitbox_Offset_Y = game::Config::tile_Size * 1.0f;

            // Verhalten (kann später pro Wand angepasst werden, falls nötig)
            inline static constexpr float movable_Wall_Sprite_Movement_Speed = 64.0f; // Geschwindigkeit der Sprite-Transition
            inline static constexpr float movable_Wall_Move_Cooldown = 0.5f;    // Abklingzeit nach Bewegung
            inline static constexpr float movable_Wall_Push_Delay = 0.2f;       // Verzögerung vor Bewegung durch Spieler

            // --- Movable Wall 1 (Spezifische Daten) ---
            // Zielposition für Wand 1 (Pixel-Koordinaten)
            inline static constexpr float movable_Wall_1_Target_X = 200.0f; // Beispiel
            inline static constexpr float movable_Wall_1_Target_Y = 100.0f; // Beispiel

            // Zielposition für Wand 2 (Pixel-Koordinaten)
            inline static constexpr float movable_Wall_1_Target_X = 200.0f; // Beispiel
            inline static constexpr float movable_Wall_1_Target_Y = 100.0f; // Beispiel

            // Zielposition für Wand 3 (Pixel-Koordinaten)
            inline static constexpr float movable_Wall_1_Target_X = 200.0f; // Beispiel
            inline static constexpr float movable_Wall_1_Target_Y = 100.0f; // Beispiel

            // Zielposition für Wand 4 (Pixel-Koordinaten)
            inline static constexpr float movable_Wall_1_Target_X = 200.0f; // Beispiel
            inline static constexpr float movable_Wall_1_Target_Y = 100.0f; // Beispiel

            // Zielposition für Wand 5 (Pixel-Koordinaten)
            inline static constexpr float movable_Wall_1_Target_X = 200.0f; // Beispiel
            inline static constexpr float movable_Wall_1_Target_Y = 100.0f; // Beispiel


            // Sprite-Pfade für Wand 1
            // Die _Top Sprites werden über dem Spieler gezeichnet, die _Bottom Sprites unter dem Spieler (bei Überlappung)
            inline static constexpr const char* movable_Wall_1_Sprite_Path_Inactive_Top = "assets/graphics/Movable_Wall_1/wall_1_inactive_top.png";
            inline static constexpr const char* movable_Wall_1_Sprite_Path_Inactive_Bottom = "assets/graphics/Movable_Wall_1/wall_1_inactive_bottom.png";

            inline static constexpr const char* movable_Wall_1_Sprite_Path_Active_Top = "assets/graphics/Movable_Wall_1/wall_1_active_top.png";
            inline static constexpr const char* movable_Wall_1_Sprite_Path_Active_Bottom = "assets/graphics/Movable_Wall_1/wall_1_active_bottom.png";

            // Sprite-Pfade für Wand 2
            // Die _Top Sprites werden über dem Spieler gezeichnet, die _Bottom Sprites unter dem Spieler (bei Überlappung)
            inline static constexpr const char* movable_Wall_2_Sprite_Path_Inactive_Top = "assets/graphics/Movable_Wall_2/wall_2_inactive_top.png";
            inline static constexpr const char* movable_Wall_2_Sprite_Path_Inactive_Bottom = "assets/graphics/Movable_Wall_2/wall_2_inactive_bottom.png";

            inline static constexpr const char* movable_Wall_2_Sprite_Path_Active_Top = "assets/graphics/Movable_Wall_2/wall_2_active_top.png";
            inline static constexpr const char* movable_Wall_2_Sprite_Path_Active_Bottom = "assets/graphics/Movable_Wall_2/wall_2_active_bottom.png";

            // Sprite-Pfade für Wand 3
            // Die _Top Sprites werden über dem Spieler gezeichnet, die _Bottom Sprites unter dem Spieler (bei Überlappung)
            inline static constexpr const char* movable_Wall_3_Sprite_Path_Inactive_Top = "assets/graphics/Movable_Wall_3/wall_3_inactive_top.png";
            inline static constexpr const char* movable_Wall_3_Sprite_Path_Inactive_Bottom = "assets/graphics/Movable_Wall_3/wall_3_inactive_bottom.png";

            inline static constexpr const char* movable_Wall_3_Sprite_Path_Active_Top = "assets/graphics/Movable_Wall_3/wall_3_active_top.png";
            inline static constexpr const char* movable_Wall_3_Sprite_Path_Active_Bottom = "assets/graphics/Movable_Wall_3/wall_3_active_bottom.png";

            // Sprite-Pfade für Wand 4
            // Die _Top Sprites werden über dem Spieler gezeichnet, die _Bottom Sprites unter dem Spieler (bei Überlappung)
            inline static constexpr const char* movable_Wall_4_Sprite_Path_Inactive_Top = "assets/graphics/Movable_Wall_4/wall_4_inactive_top.png";
            inline static constexpr const char* movable_Wall_4_Sprite_Path_Inactive_Bottom = "assets/graphics/Movable_Wall_4/wall_4_inactive_bottom.png";

            inline static constexpr const char* movable_Wall_4_Sprite_Path_Active_Top = "assets/graphics/Movable_Wall_4/wall_4_active_top.png";
            inline static constexpr const char* movable_Wall_4_Sprite_Path_Active_Bottom = "assets/graphics/Movable_Wall_4/wall_4_active_bottom.png";

            // Sprite-Pfade für Wand 5
            // Die _Top Sprites werden über dem Spieler gezeichnet, die _Bottom Sprites unter dem Spieler (bei Überlappung)
            inline static constexpr const char* movable_Wall_5_Sprite_Path_Inactive_Top = "assets/graphics/Movable_Wall_5/wall_5_inactive_top.png";
            inline static constexpr const char* movable_Wall_5_Sprite_Path_Inactive_Bottom = "assets/graphics/Movable_Wall_5/wall_5_inactive_bottom.png";

            inline static constexpr const char* movable_Wall_5_Sprite_Path_Active_Top = "assets/graphics/Movable_Wall_5/wall_5_active_top.png";
            inline static constexpr const char* movable_Wall_5_Sprite_Path_Active_Bottom = "assets/graphics/Movable_Wall_5/wall_5_active_bottom.png";

    };
}
